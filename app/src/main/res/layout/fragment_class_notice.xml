<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout for ClassNoticeFragment (CLASS tab).

    FrameLayout root holds three children whose visibility is toggled in code:
      • rvClassList          – teacher's scrollable class list (initially VISIBLE for teacher)
      • classNoticeContainer – hosts NoticeListFragment once a class is selected (initially GONE)
      • fabClassNotice       – teacher-only FAB for posting to the selected class (initially GONE)
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Class list shown to teacher (or empty state) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvClassList"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="80dp"
        android:visibility="gone" />

    <!-- Hosts NoticeListFragment once a class is selected or for student direct view -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/classNoticeContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- Teacher-only FAB: posts a new notice for the currently viewed class -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabClassNotice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:contentDescription="Add Class Notice"
        android:src="@drawable/ic_new_chat"
        android:visibility="gone"
        app:backgroundTint="@color/colorPrimary"
        app:elevation="6dp"
        app:tint="@color/white" />

</FrameLayout>