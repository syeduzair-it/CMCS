<?xml version="1.0" encoding="utf-8"?>
<!--
  fragment_notice.xml (Phase 3 — Simplified)
  
  Toolbar removed — now owned by MainActivity
  TabLayout + ViewPager2 kept for notice categories
  FAB removed — will be managed by NoticeFragment programmatically
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cmcs_background">

    <!-- TabLayout for notice categories -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/noticeTabLayout"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/cmcs_primary"
        app:tabGravity="fill"
        app:tabIndicatorColor="@android:color/white"
        app:tabIndicatorHeight="3dp"
        app:tabMode="fixed"
        app:tabSelectedTextColor="@android:color/white"
        app:tabTextColor="#CCFFFFFF"
        app:tabTextAppearance="@style/TabTextAppearance" />

    <!-- ViewPager2 for notice lists -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/noticeViewPager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="48dp"
        android:layout_marginBottom="@dimen/_80sdp" />

    <!-- FAB for adding notices (teacher only) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddNotice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="@dimen/_20sdp"
        android:layout_marginBottom="@dimen/_80sdp"
        android:contentDescription="Add Notice"
        android:src="@drawable/ic_new_chat"
        android:visibility="gone"
        app:backgroundTint="@color/cmcs_primary"
        app:tint="@color/white"
        app:elevation="8dp"
        app:fabSize="normal" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
