<?xml version="1.0" encoding="utf-8"?>
<!--
  item_user.xml — Row layout for SelectUserActivity's RecyclerView.

  Structure:
  ConstraintLayout
    ├── FrameLayout (avatar + teacher badge overlay)
    │     ├── CircleImageView  – avatar
    │     └── ImageView        – teacher badge (bottom|end, teachers only)
    ├── TextView  name
    ├── TextView  subtitle
    └── CheckBox  (group selection mode)
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <!-- Avatar + teacher badge overlay -->
    <FrameLayout
        android:id="@+id/user_avatar_frame"
        android:layout_width="48dp"
        android:layout_height="48dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/user_avatar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_drawer_profile"
            app:civ_border_color="@color/surfaceElevated"
            app:civ_border_width="1.5dp" />

        <!-- Teacher verification badge — bottom-right corner -->
        <ImageView
            android:id="@+id/user_teacher_badge"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="bottom|end"
            android:background="@drawable/ic_teacher_badge_dark"
            android:src="@drawable/ic_teacher"
            android:tint="@color/white"
            style="@style/ShapeAppearance.Material3.Tooltip"
            android:padding="4dp"
            android:elevation="2dp"
            android:visibility="gone"
            android:importantForAccessibility="no" />

    </FrameLayout>

    <!-- Name -->
    <TextView
        android:id="@+id/user_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="8dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/textPrimary"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/user_checkbox"
        app:layout_constraintStart_toEndOf="@id/user_avatar_frame"
        app:layout_constraintTop_toTopOf="@id/user_avatar_frame"
        tools:text="Ahmad Raza" />

    <!-- Checkbox for group selection -->
    <CheckBox
        android:id="@+id/user_checkbox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Subtitle: dept / course / year -->
    <TextView
        android:id="@+id/user_subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginTop="3dp"
        android:layout_marginEnd="8dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/textSecondary"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="@id/user_avatar_frame"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/user_avatar_frame"
        app:layout_constraintTop_toBottomOf="@id/user_name"
        tools:text="Student · CS · Year 2" />

</androidx.constraintlayout.widget.ConstraintLayout>
