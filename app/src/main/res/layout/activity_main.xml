<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_main.xml — Global Screen Scaffold (Phase 3)
  
  Architecture:
  CoordinatorLayout (root, handles system insets)
    ├─ AppBarLayout (toolbar container)
    │    └─ MaterialToolbar (global toolbar, managed by MainActivity)
    ├─ FragmentContainerView (scrollable content area)
    ├─ BottomNavigationView (anchored to bottom)
    └─ FloatingActionButton (anchored above bottom nav)
  
  Benefits:
  • Single toolbar owned by activity (fragments only provide content)
  • Single FAB (no duplicates in fragments)
  • Stable bottom navigation (doesn't move between fragments)
  • Proper WindowInsets handling (edge-to-edge)
  • CoordinatorLayout scroll behavior (toolbar can collapse if needed)
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/cmcs_background">

    <!-- ══════════════════════════════════════════════════════════════════
         GLOBAL TOOLBAR (owned by MainActivity)
         ══════════════════════════════════════════════════════════════════ -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true"
        android:backgroundTint="@color/cmcs_primary"
        app:elevation="4dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            style="@style/CMCS.Toolbar"
            app:title="CMCS"
            app:titleTextAppearance="@style/CMCS.Toolbar.TitleText"
            app:navigationIcon="@drawable/ic_menu" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ══════════════════════════════════════════════════════════════════
         FRAGMENT CONTAINER (scrolls under toolbar)
         ══════════════════════════════════════════════════════════════════ -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

    <!-- ══════════════════════════════════════════════════════════════════
         BOTTOM NAVIGATION (stable, anchored to bottom)
         ══════════════════════════════════════════════════════════════════ -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavView"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_gravity="bottom"
        android:background="@color/white"
        android:elevation="12dp"
        app:itemIconSize="22dp"
        app:itemIconTint="@color/nav_item_color"
        app:itemTextColor="@color/nav_item_color"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu" />

    <!-- ══════════════════════════════════════════════════════════════════
         SCANNER FAB (permanent, centered above bottom nav)
         ══════════════════════════════════════════════════════════════════ -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabScanner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="Scanner"
        android:src="@drawable/ic_camera"
        android:backgroundTint="@color/cmcs_primary_dark"
        android:tint="@android:color/white"
        app:layout_anchor="@id/bottomNavView"
        app:layout_anchorGravity="top|center"
        app:elevation="8dp"
        app:fabSize="normal" />

    <!-- ══════════════════════════════════════════════════════════════════
         ACTION FAB (dynamic, bottom-right corner)
         ══════════════════════════════════════════════════════════════════ -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="@dimen/_20sdp"
        android:layout_marginBottom="@dimen/_80sdp"
        android:contentDescription="Action"
        android:src="@drawable/ic_new_chat"
        android:visibility="gone"
        android:backgroundTint="@color/cmcs_primary"
        android:tint="@android:color/white"
        app:elevation="8dp"
        app:fabSize="normal" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
