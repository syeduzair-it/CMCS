<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_chat_r.xml
  Modern immersive chat interface with seamless status bar integration
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_chatactivity">

    <!-- Modern Chat Header with seamless status bar -->
    <LinearLayout
        android:id="@+id/chatHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="?attr/actionBarSize"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/cmcs_primary"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Back Button -->
        <ImageView
            android:id="@+id/backBtn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="12dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            app:tint="@color/white" />

        <!-- User Avatar + teacher badge overlay -->
        <FrameLayout
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginStart="4dp">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/userImage"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/ic_user"
                app:civ_border_width="2dp"
                app:civ_border_color="@color/white" />

            <ImageView
                android:id="@+id/iv_teacher_badge"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="bottom|end"
                android:background="@drawable/ic_teacher_badge"
                android:src="@drawable/ic_teacher"
                android:tint="@color/cmcs_primary_dark"

                android:padding="3dp"
                android:elevation="2dp"
                android:visibility="gone"
                android:importantForAccessibility="no" />

        </FrameLayout>

        <!-- Username -->
        <TextView
            android:id="@+id/username"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Username"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end"
            android:layout_weight="1" />

        <!-- Options Menu -->
        <ImageView
            android:id="@+id/options"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="12dp"
            android:src="@drawable/ic_menu"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Options"
            app:tint="@color/white" />

    </LinearLayout>

    <!-- Messages RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chatRecyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="8dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/chatHeader"
        app:layout_constraintBottom_toTopOf="@id/layout_reply_preview"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Reply Preview Bar -->
    <LinearLayout
        android:id="@+id/layout_reply_preview"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/surfaceElevated"
        android:padding="12dp"
        android:elevation="2dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/chatInputContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Reply Indicator Line -->
        <View
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="@color/cmcs_primary"
            android:layout_marginEnd="8dp" />

        <!-- Reply Text -->
        <TextView
            android:id="@+id/tv_reply_preview_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Replying..."
            android:textColor="@color/textPrimary"
            android:textSize="14sp"
            android:maxLines="2"
            android:ellipsize="end" />

        <!-- Cancel Reply Button -->
        <ImageButton
            android:id="@+id/btn_cancel_reply"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_close"
            android:contentDescription="Cancel reply"
            app:tint="@color/textSecondary" />
    </LinearLayout>

    <!-- Modern Message Input Container -->
    <LinearLayout
        android:id="@+id/chatInputContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:elevation="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Input Row -->
        <LinearLayout
            android:id="@+id/chatInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Attachment Button -->
            <ImageView
                android:id="@+id/btn_attach"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@drawable/ic_attach"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Attach"
                app:tint="@color/cmcs_primary" />

            <!-- Modern Rounded Message Input -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/surfaceElevated">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp">

                    <!-- Emoji Button -->
                    <ImageView
                        android:id="@+id/btn_emoji"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:padding="4dp"
                        android:src="@drawable/ic_emoji"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Emoji"
                        app:tint="@color/textSecondary" />

                    <!-- Message Input Field -->
                    <EditText
                        android:id="@+id/messageInput"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:minHeight="36dp"
                        android:maxHeight="120dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:background="@android:color/transparent"
                        android:hint="Message"
                        android:textColor="@color/textPrimary"
                        android:textColorHint="@color/textSecondary"
                        android:textSize="16sp"
                        android:inputType="textMultiLine|textCapSentences"
                        android:maxLines="6"
                        android:scrollbars="vertical" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Voice/Send Button -->
            <androidx.cardview.widget.CardView
                android:layout_width="48dp"
                android:layout_height="48dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/cmcs_primary">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <!-- Voice Button (default visible) -->
                    <ImageView
                        android:id="@+id/sendVoice"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="12dp"
                        android:src="@drawable/ic_mic"
                        android:contentDescription="Voice message"
                        app:tint="@color/white" />

                    <!-- Send Button (shown when typing) -->
                    <ImageView
                        android:id="@+id/btn_send"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="12dp"
                        android:src="@drawable/ic_send"
                        android:visibility="gone"
                        android:contentDescription="Send message"
                        app:tint="@color/white" />

                </FrameLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>