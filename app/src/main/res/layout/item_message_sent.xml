<?xml version="1.0" encoding="utf-8"?>
<!--  Sent message row (right-aligned)  -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_message_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:orientation="vertical"
        android:paddingStart="56dp"
        android:paddingEnd="12dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <!-- Bubble card -->
        <LinearLayout
            android:id="@+id/bubble_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bubble_sent"
            android:elevation="2dp"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="6dp">

            <!-- Forwarded Indicator -->
            <TextView
                android:id="@+id/tv_forwarded"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Forwarded"
                android:textColor="#DDDDDD"
                android:textSize="10sp"
                android:textStyle="italic"
                android:drawableStart="@drawable/ic_forward"
                android:drawablePadding="4dp"
                android:drawableTint="#DDDDDD"
                android:visibility="gone"
                android:layout_marginBottom="4dp" />

            <!-- Reply Block -->
            <LinearLayout
                android:id="@+id/layout_reply"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#20FFFFFF"
                android:padding="6dp"
                android:layout_marginBottom="6dp"
                android:visibility="gone">
                <View
                    android:layout_width="3dp"
                    android:layout_height="match_parent"
                    android:background="@color/white"
                    android:layout_marginEnd="6dp" />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Replying to:"
                        android:textColor="@color/white"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tv_reply_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:maxWidth="220dp"
                        android:maxLines="2"
                        android:ellipsize="end"
                        android:textColor="#EEEEEE"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Message text -->
            <TextView
                android:id="@+id/tv_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="260dp"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:lineSpacingMultiplier="1.2" />

            <!-- Bottom row: timestamp + status dot -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="3dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_timestamp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#CCE8E0FF"
                    android:textSize="10sp" />

                <!-- Status dot  ●  -->
                <View
                    android:id="@+id/view_status_dot"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_marginStart="5dp"
                    android:background="@drawable/status_dot_sent"
                    android:backgroundTint="#FFFFFF" />

            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</FrameLayout>