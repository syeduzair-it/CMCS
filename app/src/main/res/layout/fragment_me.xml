<?xml version="1.0" encoding="utf-8"?>
<!--
  fragment_me.xml (Phase 3 — Simplified)
  
  Toolbar removed — now owned by MainActivity
  DrawerLayout kept for navigation drawer functionality
-->
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/me_drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".fragments.MeFragment">

    <!-- ════════════════════════════════════════
         MAIN CONTENT
         ════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:background="@color/cmcs_background">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/_80sdp">

            <!-- ─── Profile Card ─────────────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/_16sdp"
                app:cardBackgroundColor="@color/cmcs_card"
                app:cardCornerRadius="@dimen/_16sdp"
                app:cardElevation="2dp"
                app:strokeColor="@color/cmcs_divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="@dimen/_20sdp">

                    <!-- Avatar + edit overlay -->
                    <FrameLayout
                        android:layout_width="@dimen/_100sdp"
                        android:layout_height="@dimen/_100sdp">

                        <de.hdodenhof.circleimageview.CircleImageView
                            android:id="@+id/ivProfileImage"
                            android:layout_width="@dimen/_100sdp"
                            android:layout_height="@dimen/_100sdp"
                            android:src="@drawable/ic_user"
                            app:civ_border_color="@color/cmcs_primary"
                            app:civ_border_width="2dp" />

                        <ProgressBar
                            android:id="@+id/pbUpload"
                            android:layout_width="@dimen/_36sdp"
                            android:layout_height="@dimen/_36sdp"
                            android:layout_gravity="center"
                            android:indeterminateTint="@color/colorPrimary"
                            android:visibility="gone" />

                        <ImageButton
                            android:id="@+id/btnEditProfileImage"
                            android:layout_width="@dimen/_30sdp"
                            android:layout_height="@dimen/_30sdp"
                            android:layout_gravity="bottom|end"
                            android:background="@color/cmcs_primary"
                            android:contentDescription="Edit profile image"
                            android:padding="@dimen/_5sdp"
                            android:src="@drawable/ic_edit" />

                    </FrameLayout>

                    <!-- Name -->
                    <TextView
                        android:id="@+id/tvName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_12sdp"
                        android:textColor="@color/textPrimary"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        tools:text="John Doe" />

                    <!-- Role badge — teacher only -->
                    <TextView
                        android:id="@+id/tvBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_4sdp"
                        android:background="@drawable/badge_teacher_bg"
                        android:paddingStart="@dimen/_10sdp"
                        android:paddingTop="@dimen/_2sdp"
                        android:paddingEnd="@dimen/_10sdp"
                        android:paddingBottom="@dimen/_2sdp"
                        android:text="Teacher"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:visibility="gone"
                        tools:visibility="visible" />

                    <!-- Email -->
                    <TextView
                        android:id="@+id/tvEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_6sdp"
                        android:textColor="@color/textSecondary"
                        android:textSize="14sp"
                        tools:text="john@example.com" />

                    <!-- Department (teacher) / Year (student) -->
                    <TextView
                        android:id="@+id/tvDepartmentOrYear"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_2sdp"
                        android:textColor="@color/textSecondary"
                        android:textSize="13sp"
                        tools:text="Year: 2" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="@dimen/_16sdp"
                android:layout_marginEnd="@dimen/_16sdp"
                android:background="@color/dividerColor" />

            <!-- ─── Role-based Menu RecyclerView ───── -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_8sdp"
                android:layout_marginBottom="@dimen/_8sdp"
                android:nestedScrollingEnabled="false"
                tools:itemCount="4"
                tools:listitem="@layout/item_me_menu" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- ════════════════════════════════════════
         NAVIGATION DRAWER (same as ChatsFragment)
         ════════════════════════════════════════ -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/me_navigation_view"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/white"
        android:fitsSystemWindows="true"
        app:headerLayout="@layout/nav_header"
        app:itemBackground="@drawable/drawer_item_background"
        app:itemIconTint="@color/nav_item_color"
        app:itemTextColor="@color/nav_item_color"
        app:menu="@menu/drawer_menu" />

</androidx.drawerlayout.widget.DrawerLayout>
