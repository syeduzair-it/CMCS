<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        Night-mode override — forces the same light purple academic palette
        regardless of system dark mode. All styles must be redeclared here
        so the night qualifier bucket is self-contained.
    -->

    <style name="Base.Theme.CMCS" parent="Theme.MaterialComponents.DayNight.NoActionBar">

        <item name="colorPrimary">@color/cmcs_primary</item>
        <item name="colorPrimaryVariant">@color/cmcs_primary_dark</item>
        <item name="colorSecondary">@color/cmcs_accent</item>
        <item name="colorAccent">@color/cmcs_accent</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/cmcs_primary_dark</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Navigation bar -->
        <item name="android:navigationBarColor">@color/cmcs_background</item>

        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/textPrimary</item>
        <item name="android:textColorSecondary">@color/textSecondary</item>

    </style>

    <style name="Theme.CMCS" parent="Base.Theme.CMCS" />

    <style name="Theme.CMCS.Splash" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@color/cmcs_background</item>
        <item name="postSplashScreenTheme">@style/Theme.CMCS</item>
    </style>

heme.CMCS">
    <!-- Fullscreen theme for story/highlight viewers -->
    <style name="Theme.CMCS.Fullscreen" parent="Theme.CMCS">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:navigationBarColor">@android:color/black</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Chat theme — seamless status bar integration -->
    <style name="Theme.CMCS.Chat" parent="Theme.CMCS">
        <item name="android:statusBarColor">@color/cmcs_primary</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

</resources>