<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="black">#FF000000</color>
    <color name="white">#FFFFFFFF</color>

    <!-- ── CMCS Purple Academic Palette ──────────────────────────────── -->
    <!-- Primary: soft lavender purple -->
    <color name="cmcs_primary">#B69FCB</color>
    <!-- Primary dark: deeper purple for pressed states / variants -->
    <color name="cmcs_primary_dark">#64427E</color>
    <!-- Accent: mid-tone purple for highlights, FABs, badges -->
    <color name="cmcs_accent">#A08AB8</color>
    <!-- Background: near-white with a faint purple warmth -->
    <color name="cmcs_background">#F2EFF7</color>
    <!-- Card surface: pure white for contrast against background -->
    <color name="cmcs_card">#FFFFFF</color>
    <!-- Divider / subtle borders -->
    <color name="cmcs_divider">#D1D0D6</color>
    <!-- Secondary text: muted grey-purple -->
    <color name="cmcs_text_secondary">#80798B</color>
    <!-- Chat bubble / tint accent -->
    <color name="cmcs_tint">#B7A0CD</color>
    <!-- Highlight accent (alias for cmcs_tint) -->
    <color name="cmcs_highlight">#B7A0CD</color>

    <!-- ── Semantic aliases (used throughout all layouts) ────────────── -->
    <!-- Remapping these to the new palette propagates the theme globally -->
    <color name="colorPrimary">@color/cmcs_primary</color>
    <color name="colorPrimaryVariant">@color/cmcs_primary_dark</color>
    <color name="colorAccent">@color/cmcs_accent</color>

    <color name="backgroundColor">@color/cmcs_background</color>
    <color name="surfaceColor">@color/cmcs_card</color>
    <!-- Slightly tinted surface for elevated elements (media bg, chat bubbles) -->
    <color name="surfaceElevated">#EDE8F4</color>

    <color name="textPrimary">#2C2C2C</color>
    <color name="textSecondary">@color/cmcs_text_secondary</color>

    <!-- Chat bubbles -->
    <color name="chatBubbleMe">@color/cmcs_primary</color>
    <color name="chatBubbleOther">#EDE8F4</color>

    <!-- Bottom navigation -->
    <color name="navSelected">@color/cmcs_primary_dark</color>
    <color name="navUnselected">#BDBDBD</color>

    <!-- FAB and highlights -->
    <color name="fabColor">@color/cmcs_primary</color>
    <color name="highlightColor">@color/cmcs_tint</color>

    <!-- Divider / borders -->
    <color name="dividerColor">@color/cmcs_divider</color>

    <!-- Legacy aliases kept for any remaining direct references -->
    <color name="lightPurple">#EDE8F4</color>
    <color name="darkPurple">@color/cmcs_primary_dark</color>
    <color name="lightGray">#BDBDBD</color>

    <!-- Message status dots -->
    <color name="statusDelivered">#F44336</color>
    <color name="statusRead">#4CAF50</color>

    <!-- Error -->
    <color name="errorColor">#FF5252</color>

</resources>
