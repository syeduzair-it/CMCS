<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera.any" />

    <!-- Media permissions — API 33+ -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <!-- Legacy for API < 33 -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <application
        android:name=".CMCSApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CMCS"
        tools:targetApi="31">
        <activity
            android:name=".ScannerOptionsActivity"
            android:exported="false" />
        <!-- Splash Activity (Launcher) -->
        <activity
            android:name=".login.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.CMCS.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <!-- Main Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true" />
        <!-- Welcome Screen -->
        <activity
            android:name=".welcome.WelcomeActivity"
            android:exported="true" />
        <!-- Login Screen -->
        <activity
            android:name=".login.Login"
            android:exported="true" />
        <!-- OTP Screen -->
        <activity
            android:name=".login.OtpVerificationActivity"
            android:exported="true" />
        <!-- Set Password Screen -->
        <activity
            android:name=".login.SetPassword"
            android:exported="true" />
        <!-- Select User (Start Chat) -->
        <activity
            android:name=".SelectUserActivity"
            android:exported="false" />
        <!-- Class Students (View class users) -->
        <activity
            android:name=".ClassStudentsActivity"
            android:exported="false" />
        <!-- Chat Screen -->
        <activity
            android:name=".ChatActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize|stateHidden" />
        <activity
            android:name=".ForwardMessageActivity"
            android:exported="false" />
        <!-- Notice System -->
        <activity
            android:name=".AddNoticeActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".NoticeViewersActivity"
            android:exported="false" />
        <activity
            android:name=".NoticeMediaViewerActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize" />
        <activity
            android:name=".NoticeVideoViewerActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize"
            android:screenOrientation="sensor" />
        <!-- Fees (student read-only) -->
        <activity
            android:name=".FeesActivity"
            android:exported="false" />
        <!-- Marksheet (student local storage) -->
        <activity
            android:name=".MarksheetActivity"
            android:exported="false" />
        <!-- University ID & Password (reauthentication gated) -->
        <activity
            android:name=".UniversityCredentialsActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <!-- Teacher Time Table (local image, teacher-only) -->
        <activity
            android:name=".TeacherTimeTableActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize" />
        <!-- Notes System — class → subject → note hierarchy -->
        <activity android:name=".NotesClassActivity" android:exported="false" />
        <activity android:name=".NotesSubjectActivity" android:exported="false" />
        <activity android:name=".NotesListActivity" android:exported="false" />
        <activity android:name=".AddNoteActivity" android:exported="false" />
        <activity android:name=".NoticesPostedActivity" android:exported="false" />
        <!-- Stories System -->
        <activity android:name=".AddStoryActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity android:name=".StoryViewerActivity"
            android:exported="false"
            android:theme="@style/Theme.CMCS.Fullscreen"
            android:configChanges="orientation|screenSize" />
        <!-- Features + Highlights System -->
        <activity android:name=".AddFeatureSlideActivity" />
        <activity android:name=".AddFeatureActivity" android:exported="false" />
        <activity android:name=".AddHighlightActivity" android:exported="false" />
        <activity android:name=".HighlightViewerActivity"
            android:exported="false"
            android:theme="@style/Theme.CMCS.Fullscreen"
            android:configChanges="orientation|screenSize" />

        <!-- Post System (Phase-3) -->
        <activity android:name=".AddPostActivity" android:exported="false" />
        <activity android:name=".PostFeedActivity" android:exported="false" />

        <!-- Attendance Module -->
        <activity android:name=".ClassSelectionActivity" android:exported="false" />
        <activity android:name=".AttendanceSessionActivity" android:exported="false" />
        <activity android:name=".StudentListAttendanceActivity" android:exported="false" />
        <activity android:name=".ScannerActivity" android:exported="false" />
        <activity android:name=".MyAttendanceActivity" android:exported="false" />

        <!-- FileProvider — share locally stored marksheet files with viewer apps -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.provider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>